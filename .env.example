# =============================================================================
# CV Tool — Environment Variable Template
# =============================================================================
# Copy this file to .env at the repository root before running docker compose:
#
#   cp .env.example .env
#
# Then edit .env to set your own values where indicated.
# Never commit .env to version control — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL database credentials
# Used by the `db` service and referenced in DATABASE_URL for the backend.
# -----------------------------------------------------------------------------
POSTGRES_USER=cvtool
POSTGRES_PASSWORD=change_me_in_dot_env
POSTGRES_DB=cvtool_dev
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Backend API server
# -----------------------------------------------------------------------------
BACKEND_PORT=3001

# -----------------------------------------------------------------------------
# Frontend dev server
# -----------------------------------------------------------------------------
FRONTEND_PORT=5173

# -----------------------------------------------------------------------------
# Database connection URL — used by the backend and the dbmate migration tool
# to connect to PostgreSQL. The hostname `db` resolves to the `db` service on
# the Docker Compose network. Must be kept in sync with POSTGRES_USER,
# POSTGRES_PASSWORD, POSTGRES_DB, and POSTGRES_PORT.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://cvtool:change_me_in_dot_env@db:5432/cvtool_dev?sslmode=disable
