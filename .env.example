# =============================================================================
# CV Tool — Environment Variable Template
# =============================================================================
# Copy this file to .env at the repository root before running docker compose:
#
#   cp .env.example .env
#
# Then edit .env to set your own values where indicated.
# Never commit .env to version control — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL database credentials
# Used by the `postgres` service and referenced in DATABASE_URL for the backend.
# -----------------------------------------------------------------------------
POSTGRES_USER=cvtool
POSTGRES_PASSWORD=change_me_in_dot_env
POSTGRES_DB=cvtool_dev

# -----------------------------------------------------------------------------
# Backend API server
# -----------------------------------------------------------------------------
BACKEND_PORT=3001

# -----------------------------------------------------------------------------
# Frontend dev server
# -----------------------------------------------------------------------------
FRONTEND_PORT=5173

# -----------------------------------------------------------------------------
# Database connection URL — used by the backend to connect to PostgreSQL.
# The hostname `postgres` resolves to the `postgres` service on the Docker
# Compose network via Docker internal DNS.
# Must be kept in sync with POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://cvtool:change_me_in_dot_env@postgres:5432/cvtool_dev
