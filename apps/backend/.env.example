# Backend environment variables
# Copy to .env and adjust values for local development (outside Docker).
#
# When running via Docker Compose, these are supplied by the root .env file.

# Port the HTTP server listens on.
BACKEND_PORT=3001

# Backend log level for pino. Common values: debug, info, warn, error.
BACKEND_LOG_LEVEL=info

# Log format for backend output. Use `pretty` for local development and `json`
# when logs should stay machine-readable.
BACKEND_LOG_FORMAT=pretty

# Optional log file sink for local tracing/debugging. Set to an empty string to
# disable file logging. Tail it with:
#   tail -f .logs/backend.log
BACKEND_LOG_FILE=.logs/backend.log

# Database connection URL for local development (db running via Docker).
# Use hostname `db` instead of `localhost` when running inside Docker Compose.
DATABASE_URL=postgresql://cvtool:change_me_in_dot_env@localhost:5432/cvtool_dev?sslmode=disable

# Backend: used to verify Microsoft Entra ID tokens server-side
ENTRA_CLIENT_ID=your_actual_client_id_here
ENTRA_TENANT_ID=your_actual_tenant_id_here

# OpenAI API key — required for AI features (improve assignment description, etc.)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# JWT secret for signing self-issued access tokens.
# Must be a strong random value (32+ bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_secret_at_least_32_bytes

# Access token expiry (default: 15m). Use ms-compatible format: 15m, 1h, etc.
JWT_EXPIRES_IN=15m

# MCP adapter: point the local stdio server at an external-AI-capable API base URL.
# Provide either an access token directly, or a one-time challenge pair so the adapter
# can exchange it on startup and then refresh automatically.
EXTERNAL_AI_MCP_BASE_URL=http://localhost:3001/api
EXTERNAL_AI_MCP_ACCESS_TOKEN=
EXTERNAL_AI_MCP_REFRESH_TOKEN=
EXTERNAL_AI_MCP_CHALLENGE_ID=
EXTERNAL_AI_MCP_CHALLENGE_CODE=
