{
  "name": "@cv-tool/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env --import tsx/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "migrate": "node --env-file=.env --import tsx/esm src/db/migrate.ts"
  },
  "dependencies": {
    "@cv-tool/contracts": "*",
    "@cv-tool/utils": "*",
    "@orpc/openapi": "^1.13.6",
    "@orpc/server": "^1.13.6",
    "@orpc/zod": "^1.13.6",
    "docx": "^9.6.1",
    "google-auth-library": "^10.6.1",
    "jose": "^6.2.2",
    "kysely": "^0.27.4",
    "mammoth": "^1.12.0",
    "openai": "^6.32.0",
    "pg": "^8.11.3",
    "postgres": "^3.4.5",
    "puppeteer": "^24.39.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cv-tool/tsconfig": "*",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^2.1.0"
  }
}
