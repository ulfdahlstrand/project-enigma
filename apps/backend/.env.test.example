# Backend integration test environment variables
#
# Copy to .env.test and point TEST_DATABASE_URL at a dedicated throwaway
# database. Integration tests truncate all public tables before each test run.

BACKEND_LOG_LEVEL=error
BACKEND_LOG_FORMAT=json
TEST_DATABASE_URL=postgresql://cvtool:change_me_in_dot_env@localhost:5432/cvtool_test?sslmode=disable
