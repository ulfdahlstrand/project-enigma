# MCP server environment variables
# Copy to .env and adjust for local development.

# Base URL of the backend API (the external-AI-capable surface).
EXTERNAL_AI_MCP_BASE_URL=http://localhost:3001

# The public URL where this MCP server is reachable by external clients (Claude, etc.).
# Used as a fallback when the server cannot detect its own public URL from request headers.
# Behind a reverse proxy (ngrok, etc.) the server auto-detects the public URL from
# X-Forwarded-Proto / X-Forwarded-Host headers, so this only matters for direct local access.
EXTERNAL_AI_MCP_PUBLIC_URL=http://127.0.0.1:8787

# The public URL of the frontend app — used as the base for the OAuth2
# authorization_endpoint (the user-facing approval page).
# When using one ngrok tunnel for everything, set this to the same tunnel URL.
EXTERNAL_AI_MCP_APP_URL=http://localhost:5173

# Network interface and port for the MCP HTTP server process.
EXTERNAL_AI_MCP_HOST=127.0.0.1
EXTERNAL_AI_MCP_PORT=8787

# Example single-ngrok-tunnel setup:
# EXTERNAL_AI_MCP_BASE_URL=https://your-ngrok-domain.ngrok-free.app/api
# EXTERNAL_AI_MCP_PUBLIC_URL=https://your-ngrok-domain.ngrok-free.app
# EXTERNAL_AI_MCP_APP_URL=https://your-ngrok-domain.ngrok-free.app
