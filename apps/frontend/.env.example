# Frontend environment variables
# Copy to .env and adjust values for local development.
#
# When running via Docker Compose, these are supplied by the root .env file.

# Port the Vite dev server listens on.
VITE_PORT=5173

# Base URL of the backend API server.
# The oRPC client reads this value at runtime — it must never be hardcoded.
# Example (local): http://localhost:3001
# Leave unset when running tests or when the backend is not needed.
VITE_API_URL=http://localhost:3001

# Proxy target for MCP server OAuth2 + MCP endpoints.
# Must match EXTERNAL_AI_MCP_HOST:EXTERNAL_AI_MCP_PORT in apps/mcp/.env.
VITE_MCP_PROXY_TARGET=http://localhost:8787

# Frontend (Vite): same client ID exposed to the browser
VITE_GOOGLE_CLIENT_ID=your_actual_client_id_here.apps.googleusercontent.com