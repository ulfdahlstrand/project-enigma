# =============================================================================
# CV Tool — .gitignore
# =============================================================================

# Environment variables — never commit secrets
.env
.env.local
.env.*.local

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.turbo/

# TypeScript
*.tsbuildinfo

# OS-specific
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
coverage/
playwright-report/
test-results/
.playwright/

# Local log files
.logs/
.backup/

# Flower orchestrator runtime data
.flower/
.claude/worktrees/

# Azure Developer CLI (azd) — local environment state
.azure/

# Local tooling artefacts
mempalace.yaml
entities.json
